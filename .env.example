# ─── Gravity Claw ─── Required Environment Variables ───

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# OpenRouter API key (sk-or-v1-...)
OPENROUTER_API_KEY=

# Comma-separated Telegram user IDs allowed to interact with the bot
# Find yours: message @userinfobot on Telegram
ALLOWED_USER_IDS=

# ─── Optional ───

# Model to use via OpenRouter (default: anthropic/claude-sonnet-4)
# See https://openrouter.ai/models for available models
# LLM_MODEL=anthropic/claude-sonnet-4

# Max tokens for LLM responses (default: 4096)
# LLM_MAX_TOKENS=4096

# Max agent loop iterations before force-stop (default: 10)
# MAX_AGENT_ITERATIONS=10

# ─── Voice (Optional) ───

# Groq API key for Whisper transcription (free at console.groq.com)
# GROQ_API_KEY=

# ElevenLabs API key for text-to-speech (elevenlabs.io)
# ELEVENLABS_API_KEY=

# ElevenLabs voice ID (default: George — deep, warm male voice)
# Browse voices: https://elevenlabs.io/voice-library
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
